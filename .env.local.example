# Copy this file to .env.local and fill in your values

DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: set to 'false' if your Postgres provider uses a self-signed certificate (e.g. Neon, Supabase, Railway)
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Optional: restrict CORS to your Shopify store domain (recommended in production)
# ALLOWED_ORIGIN=https://your-store.myshopify.com

# Shopify store domain (e.g. your-store.myshopify.com) — no https:// prefix
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# Shopify Admin API access token — requires the write_draft_orders permission.
# In your Shopify Partner Dashboard: Apps → your app → API credentials → Admin API access token.
# This is the token that starts with shpat_ (for custom apps) — NOT the client secret (shpss_...).
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shopify webhook signing secret — found in the Partner Dashboard under your app's
# Webhooks section, or in your store admin under Settings → Notifications → Webhooks.
# Register the orders/paid topic pointing to https://<your-domain>/api/shopify-webhook
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here
