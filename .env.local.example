# Copy this file to .env.local and fill in your values

DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: set to 'false' if your Postgres provider uses a self-signed certificate (e.g. Neon, Supabase, Railway)
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Optional: restrict CORS to your Shopify store domain (recommended in production)
# ALLOWED_ORIGIN=https://your-store.myshopify.com

# Shopify store domain (e.g. your-store.myshopify.com) — no https:// prefix
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# Shopify Partner app credentials — found in the Partner Dashboard under Apps → your app → API credentials.
# Client ID is the public identifier; Client Secret (shpss_...) is used to sign OAuth requests.
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public URL of this deployment (used to build the OAuth redirect URI).
# On Vercel this is typically https://<your-project>.vercel.app
APP_URL=https://your-app.vercel.app

# Optional: if you already have an offline Admin API access token from a previous OAuth
# installation, you can set it here to skip the database look-up on every request.
# Leave blank to rely on the token stored by the OAuth flow (/api/shopify/install).
# SHOPIFY_ADMIN_ACCESS_TOKEN=

# Shopify webhook signing secret — found in the Partner Dashboard under your app's
# Webhooks section. Register the orders/paid topic pointing to
# https://<your-domain>/api/shopify-webhook
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here
